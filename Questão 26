programa {
  funcao inicio() {
    inteiro valor , n100 , n50 , n10 , n5 , n1
    escreva("digite o valor")
    leia(valor)
    n100 = valor/100
    valor = valor % 100
    n50 = valor/50
    valor = valor % 50
    n10 = valor/10
    valor = valor % 10
    n5 = valor/5
    valor = valor % 5
    n1 = valor
    escreva("notas de 100", n100, "\n")
    escreva("notas de 50", n50, "\n")
    escreva("notas de 10", n10, "\n")
    escreva("notas de 5", n5, "\n")
    escreva("notas de 1", n1)
  }
}
