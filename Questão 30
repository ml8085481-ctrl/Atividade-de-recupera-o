programa {
  funcao inicio() {
    real indice
    escreva("digite o indice da poluicao ")
    leia(indice)
    se(indice >= 0.5){
      escreva("todos os grupos devem suspender suas atividades ")
    }
    senao se(indice>= 0.4){
      escreva("1 e 2 grupos devem suspender suas atividades")
    }
    senao se(indice >= 0.3){
      escreva("grupo 1 deve suspender as atividades")
    }
    senao{
      escreva("indice aceitavel ")
    }
  }
}
