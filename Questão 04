programa {
  funcao inicio() {
    inteiro anos , meses, dias, totaldias
    escreva("digite o total de dias ")
    leia(totaldias)
    anos <- totaldias div 365
    totaldias <- totaldias mod 365
    meses <- totaldias div 30
    dias <- totaldias mod 30
    escreva("anos", anos)
    escreva("\nmeses", meses)
    escreva("\ndias", dias)

  }
}
