programa {
  funcao inicio() {
    real a , b , c , d, e , f
    real x , y
    escreva("digite a")
    leia(a)
    escreva("digite b")
    leia(b)
    escreva("digite c")
    leia(c)
    escreva("digite d")
    leia(d)
    escreva("digite e")
    leia(e)
    escreva("digita f")
    leia(f)
    x = (c * e - b * f) / (a * e - b * d)
    y = (a * f - c * d) / (a * e - b * d)
    escreva("o valor de x = ", x ,"\n")
    escreva(" o valor de y = ", y)
  }
}
