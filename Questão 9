programa {
  funcao inicio() {
    real n1 ,n2 ,n3 ,media
    escreva("digite a primeira nota")
    leia(n1)
    escreva("digite a segunda nota")
    leia(n2)
    escreva("digite a terceira nota")
    leia(n3)
    media = (n1 + n2 + n3) / 3
    escreva("média",media ,"\n")
    se (media >= 6 ){
      escreva("aprovado ")
    }
    senao{
      escreva("reprovado ")
    }
  }
}
