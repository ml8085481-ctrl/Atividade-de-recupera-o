programa {
  funcao inicio() {
    inteiro idade
    escreva("digite sua idade")
    leia(idade)
    se(idade >= 5 e idade<= 7){
      escreva("infantil A")
    }
    senao se(idade >= 8 e idade<= 10){
      escreva("infantil B")
    }
    senao se(idade >= 11 e idade <= 13){
      escreva("juvenil A")
    }
    senao se(idade >= 14 e idade <= 17){
      escreva("juvenil B")
    }
    senao se(idade >= 18){
      escreva("adulto ")
    }
    senao{
      escreva("idade inválida ")
    }
  }
}
