programa {
inclua biblioteca Matematica -->mat
  funcao inicio() {
    real x1 , y1 , x2 , y2 , d
    escreva("digite x1")
    leia(x1)
    escreva("digite y1")
    leia(y1)
    escreva("digite x2")
    leia(x2)
    escreva("digite y2")
    leia(y2)
    d = mat.raiz((x2 - x1) * (x2 - x1) + (y2 - y1) * (y2 - y1), 2.0)
    escreva("a distância entre os pontos é:", d)
  }
}
